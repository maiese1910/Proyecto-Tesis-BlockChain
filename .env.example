# ─── Archivo de ejemplo para configuración ───────────────────────────────────
# Copia este archivo, renómbralo a ".env" y rellena los valores reales.
# NUNCA subas el archivo ".env" real a GitHub.
# Comparte los valores reales con tu compañero por WhatsApp o mensaje directo.
# ─────────────────────────────────────────────────────────────────────────────

# ── MetaMask / Blockchain ─────────────────────────────────────────────────────
# Tu dirección de wallet MetaMask (pública, esta SÍ puede compartirse)
METAMASK_WALLET_ADDRESS=0xTU_WALLET_AQUI

# Clave privada de MetaMask — NUNCA la compartas por email ni GitHub
# Encuéntrala en: MetaMask → ⋮ → Detalles de cuenta → Exportar clave privada
METAMASK_PRIVATE_KEY=TU_CLAVE_PRIVADA_AQUI

# ── Infura (Proveedor de Sepolia RPC) ─────────────────────────────────────────
# Crea tu proyecto en https://infura.io → copia el endpoint de Sepolia
WEB3_PROVIDER_URL=https://sepolia.infura.io/v3/TU_PROJECT_ID_AQUI

# Dirección del contrato desplegado en Sepolia (se obtiene al hacer Deploy en Remix)
CONTRACT_ADDRESS=0xDIRECCION_DEL_CONTRATO_AQUI

# ── IPFS / Pinata ────────────────────────────────────────────────────────────
PINATA_API_KEY=TU_PINATA_API_KEY_AQUI
PINATA_SECRET_KEY=TU_PINATA_SECRET_AQUI

# ── APIs Opcionales ───────────────────────────────────────────────────────────
OPENAI_API_KEY=TU_OPENAI_KEY_AQUI
